@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<section class="py-5 text-center">
    <div class="container">

        <h2 class="text-success fw-bold">🎉 Đặt hàng thành công!</h2>

        <p class="mt-3 fs-5">
            Cảm ơn bạn đã mua hàng tại <strong>BHGD Store</strong>.
        </p>

        <p class="fs-5">
            Mã đơn hàng của bạn là:
            <strong class="text-primary">@ViewBag.OrderId</strong>
        </p>

        <a href="/" class="btn btn-primary mt-4">
            Quay về trang chủ
        </a>

        <a href="/Product" class="btn btn-outline-primary mt-4 ms-2">
            Tiếp tục mua sắm
        </a>

    </div>
</section>