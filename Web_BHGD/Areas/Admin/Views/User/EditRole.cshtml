@model Web_BHGD.Areas.Admin.Models.UserRolesViewModel

@{
    ViewData["Title"] = "Phân quyền: " + Model.FullName;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-card animate__animated animate__fadeIn">

    <!-- HEADER -->
    <div class="card-header py-3 d-flex justify-content-between align-items-center border-bottom">
        <h3 class="fw-bold mb-0">
            <i class="fas fa-user-shield text-primary me-2"></i>
            Phân quyền người dùng
        </h3>

        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="fas fa-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="card-body px-4 py-4">

        <!-- ALERT -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success rounded-3 shadow-sm">
                <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger rounded-3 shadow-sm">
                <i class="fas fa-times-circle me-2"></i> @TempData["Error"]
            </div>
        }

        <div class="row justify-content-center">
            <div class="col-lg-6">

                <div class="bg-white shadow-sm rounded-4 p-4">

                    <!-- USER INFO -->
                    <div class="text-center mb-4">
                        <i class="fas fa-user-circle fa-4x text-secondary mb-2"></i>
                        <h4 class="fw-bold">@Model.FullName</h4>
                        <p class="text-muted mb-0">Chọn vai trò mới cho người dùng.</p>
                    </div>

                    <!-- FORM -->
                    <form asp-action="EditRole" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="id" value="@Model.UserId" />

                        <label class="fw-bold mb-2">
                            <i class="fas fa-list-check text-primary me-2"></i>
                            Vai trò hiện tại
                        </label>

                        <select name="newRole" class="form-select form-select-lg mb-4">
                            @foreach (var role in Model.AllRoles)
                            {
                                <option value="@role"
                                        selected="@(Model.UserRoles.Contains(role) ? "selected" : null)">
                                    @role
                                </option>
                            }
                        </select>

                        <!-- SUBMIT -->
                        <button type="submit"
                                class="btn btn-primary w-100 py-2 rounded-3 fw-bold shadow-sm">
                            <i class="fas fa-save me-2"></i> Lưu thay đổi
                        </button>

                    </form>

                </div>

            </div>
        </div>

    </div>

</div>